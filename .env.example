NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# nobetecza.com — senkron için X-API-Key (okuma Supabase’ten)
NOBETECZA_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Günlük senkron: curl -H "Authorization: Bearer $CRON_SECRET" https://<domain>/api/cron/sync-pharmacies
CRON_SECRET=

# Blog admin: /admin/blog — Authorization: Bearer <ADMIN_SECRET>
ADMIN_SECRET=teSt1234613asxdasxdsaxd12312dgdf

# nobetecza ~1 istek/s; iller arası bekleme (ms). Varsayılan 1100.
# NOBETECZA_SYNC_DELAY_MS=1100
# veya kısa isim: SYNC_DELAY_MS=850

# Tam senkron öncesi tek il ile hazırlık kontrolü (varsayılan: açık). Kapatmak: 0 veya false
# NOBETECZA_PROBE_BEFORE_SYNC=false
# NOBETECZA_PROBE_IL=İstanbul

# Sadece hazırlık kontrolü (1 istek): GET /api/cron/nobetecza-ready + Authorization: Bearer CRON_SECRET

# Nöbet günü el değişimi TRT (varsayılan 8)
# DUTY_HANDOVER_HOUR_TRT=8
