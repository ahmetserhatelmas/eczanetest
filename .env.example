NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
COLLECT_API_KEY=

# Supabase (okuma: anon key + RLS; senkron: service role) — değerleri Dashboard > Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Nöbet listesi günü: bu saatten önce (TRT) takvim “dünün” nöbeti sayılır. Varsayılan 8.
# DUTY_HANDOVER_HOUR_TRT=8

# Cron: curl -H "Authorization: Bearer $CRON_SECRET" https://your-domain/api/cron/sync-pharmacies
CRON_SECRET=

# CollectAPI hız limiti: iller arası bekleme (ms). Gerekirse 1200–2000 yapın.
SYNC_DELAY_MS=850
